<Page x:Class="HUCE_DALTUD_LOPNV90_2026_0053867.Pages.pageTietDien"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HUCE_DALTUD_LOPNV90_2026_0053867.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="pageTietDien" Background="#DDDDDD">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1" Grid.Column="1" Background="White" CornerRadius="5" Margin="10,0,10,90" BorderBrush="#BBBBBB" BorderThickness="1">
            <Grid>
                <Canvas x:Name="cvTietDien"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="200"
                        Height="300">
                    <Canvas.RenderTransform>
                        <ScaleTransform ScaleX="0.5" ScaleY="0.5" CenterX="100" CenterY="150"/>
                    </Canvas.RenderTransform>

                    <Path Stroke="Black" StrokeThickness="3" Fill="Gray" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path.Data>
                            <CombinedGeometry GeometryCombineMode="Union">
                                <CombinedGeometry.Geometry1>
                                    <RectangleGeometry x:Name="geoCanhTren"/>
                                </CombinedGeometry.Geometry1>

                                <CombinedGeometry.Geometry2>
                                    <CombinedGeometry GeometryCombineMode="Union">
                                        <CombinedGeometry.Geometry1>
                                            <RectangleGeometry x:Name="geoBung"/>
                                        </CombinedGeometry.Geometry1>

                                        <CombinedGeometry.Geometry2>
                                            <RectangleGeometry x:Name="geoCanhDuoi"/>
                                        </CombinedGeometry.Geometry2>
                                    </CombinedGeometry>
                                </CombinedGeometry.Geometry2>
                            </CombinedGeometry>
                        </Path.Data>
                    </Path>
                </Canvas>
                <TextBlock Text="Hình ảnh tiết diện (mm)" FontSize="11" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
            </Grid>
        </Border>

        <TextBlock Text="Thông số cột thép chữ I" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.ColumnSpan="2"/>

        <StackPanel Grid.Row="1" Grid.Column="0">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="10">
                    <TextBlock Text="Tên tiết diện" FontSize="13"/>
                    <TextBox FontSize="13" HorizontalAlignment="Left" Name="txtName" Width="200" Margin="0 0 0 20" Background="White"/>
                </StackPanel>
                <StackPanel Margin="10">
                    <TextBlock Text="Bề rộng cánh (b)" FontSize="13"/>
                    <TextBox FontSize="13" HorizontalAlignment="Left" Name="txtRongCanh" Width="200" Margin="0 0 0 20" Background="White" TextChanged="TextBox_TextChanged"/>
                </StackPanel>
                <StackPanel Margin="10">
                    <TextBlock Text="Độ dày cánh (tf)" FontSize="13"/>
                    <TextBox FontSize="13" HorizontalAlignment="Left" Name="txtDayCanh" Width="200" Margin="0 0 0 20" Background="White" TextChanged="TextBox_TextChanged"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="10">
                    <TextBlock Text="Chiều cao bụng (h)" FontSize="13"/>
                    <TextBox FontSize="13" HorizontalAlignment="Left" Name="txtCaoBung" Width="200" Margin="0 0 0 20" Background="White" TextChanged="TextBox_TextChanged"/>
                </StackPanel>
                <StackPanel Margin="10">
                    <TextBlock Text="Độ dày bụng (tw)" FontSize="13"/>
                    <TextBox FontSize="13" HorizontalAlignment="Left" Name="txtDayBung" Width="200" Margin="0 0 0 2" Background="White" TextChanged="TextBox_TextChanged"/>
                </StackPanel>
            </StackPanel>

            <GroupBox Header="Danh sách vật liệu đã lưu" Margin="10">
                <DataGrid Name="dtgTietDien"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding clsTietDien}"
                  IsReadOnly="True"
                  SelectionChanged="dtgTietDien_SelectionChanged">  
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="*" Header="Tên" Binding="{Binding Name}" />
                        <DataGridTextColumn Width="*" Header="Chiều rộng cánh" Binding="{Binding ChieuRongCanh}" />
                        <DataGridTextColumn Width="*" Header="Chiều dày cánh" Binding="{Binding DoDayCanh}"/>
                        <DataGridTextColumn Width="*" Header="Chiều cao bụng" Binding="{Binding ChieuCaoBung}" />
                        <DataGridTextColumn Width="*" Header="Chiều dày bụng" Binding="{Binding DoDayBung}" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </StackPanel>

        <Button Grid.Row="1" Grid.Column="1" VerticalAlignment="Top" x:Name="btnThem" Content="Lưu" Width="130" Height="45" Margin="95,430,0,0" HorizontalAlignment="Left" Background="#00CC33" Foreground="Black" Click="btnThem_Click" RenderTransformOrigin="-0.075,-2.796"/>
    </Grid>
</Page>