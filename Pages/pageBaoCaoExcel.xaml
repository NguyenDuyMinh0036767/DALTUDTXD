<Page x:Class="HUCE_DALTUD_LOPNV90_2026_0053867.Pages.pageBaoCaoExcel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HUCE_DALTUD_LOPNV90_2026_0053867.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="pageBaoCaoExcel">



    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- TIÊU ĐỀ -->
        <Border Grid.Row="0"
            Background="#777777"
            CornerRadius="8"
            Margin="0,0,0,10">

            <TextBlock Text="BÁO CÁO KIỂM TRA CỘT THÉP CHỮ I"
                   Foreground="White"
                   FontSize="22"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"/>
        </Border>

        <!-- THỐNG KÊ -->
        <Border Grid.Row="1"
            Background="#DDDDDD"
            BorderBrush="#D0D0D0"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            Margin="0,0,0,10">

            <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center">

                <TextBlock Text="Tổng số cột:"
                       FontWeight="Bold"/>

                <TextBlock x:Name="txtTongCot"
                       Margin="5,0,25,0"/>

                <TextBlock Text="Đạt:"
                       FontWeight="Bold"/>

                <TextBlock x:Name="txtDat"
                       Foreground="Green"
                       Margin="5,0,25,0"/>

                <TextBlock Text="Không đạt:"
                       FontWeight="Bold"/>

                <TextBlock x:Name="txtKhongDat"
                       Foreground="Red"
                       Margin="5,0,0,0"/>

            </StackPanel>

        </Border>

        <!-- BẢNG DỮ LIỆU -->
        <DataGrid x:Name="dgBaoCao"
              Grid.Row="2"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              CanUserAddRows="False"
              HeadersVisibility="Column"
              AlternatingRowBackground="#DDDDDD"
              RowHeight="35"
              Margin="0,0,0,10">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"
                        Value="#777777"/>
                    <Setter Property="Foreground"
                        Value="White"/>
                    <Setter Property="FontWeight"
                        Value="Bold"/>
                    <Setter Property="Height"
                        Value="40"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>

                <DataGridTextColumn Header="Tên cột"
                                Width="120"
                                Binding="{Binding TenCot}"/>

                <DataGridTextColumn Header="Tiết diện"
                                Width="120"
                                Binding="{Binding TietDien}"/>

                <DataGridTextColumn Header="Kiểm tra bền"
                                Width="120"
                                Binding="{Binding KTBen}"/>

                <DataGridTextColumn Header="Ổn định tổng thể"
                                Width="150"
                                Binding="{Binding KTODTT}"/>

                <DataGridTextColumn Header="Ổn định cục bộ"
                                Width="150"
                                Binding="{Binding KTODCB}"/>

                <DataGridTextColumn Header="Khả năng chịu nén"
                                Width="150"
                                Binding="{Binding KNCN}"/>

            </DataGrid.Columns>

        </DataGrid>

        <!-- NÚT XUẤT -->
        <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                HorizontalAlignment="Right">

            <Button Width="170"
                Height="40"
                Background="#00FF00"
                Foreground="Black"
                FontWeight="Bold"
                Click="btnXuatExcel_Click">

                <StackPanel Orientation="Horizontal">

                    <Image Source="/Resources/Anh/excel.png"
                       Width="22"
                       Height="22"/>

                    <TextBlock Text="Xuất Excel"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"/>

                </StackPanel>

            </Button>

        </StackPanel>

    </Grid>
</Page>
