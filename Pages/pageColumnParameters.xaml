<Page x:Class="HUCE_DALTUD_LOPNV90_2026_0053867.Pages.pageColumnParameters"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
          xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
          xmlns:local="clr-namespace:HUCE_DALTUD_LOPNV90_2026_0053867.Pages"
          xmlns:helix="http://helix-toolkit.org/wpf"
          mc:Ignorable="d" 
          x:Name="pgCLParameter"
          DataContext="{StaticResource CLParameterVM}"
          d:DesignHeight="600" d:DesignWidth="1100"
          Title="pageColumnParameters" Background="#DDDDDD">
    <Page.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="3,0,0,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="65*" />
            <ColumnDefinition Width="35*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="280"/>
            </Grid.RowDefinitions>

            <GroupBox Header="Thông số tiết diện" Margin="10,10,10,0" HorizontalAlignment="Stretch" VerticalAlignment="Top" FontWeight="Bold" Height="220">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="10,5,10,0">
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Tên cột:" Width="110"/>
                            <TextBox Name="txtName" Width="150" Height="28" Background="White" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Chọn tiết diện:" Width="110"/>
                            <ComboBox x:Name="cbbTietDien" Width="150" Height="28" Background="White"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Tải trọng chân (N):" Width="110"/>
                            <TextBox Name="txtTaiTrongchan" Width="150" Height="28" Background="White"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Tải trọng đỉnh (N):" Width="110"/>
                            <TextBox Name="txtTaiTrongdinh" Width="150" Height="28" Background="White"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,5,10,0">
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Chọn vật liệu:" Width="110"/>
                            <ComboBox Name="cbbVatLieu" Width="150" Height="28"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Liên kết chân:" Width="110"/>
                            <ComboBox Name="cbbLK" Width="150" Height="28" HorizontalContentAlignment="Center">
                                <ComboBoxItem IsSelected="True">Ngàm</ComboBoxItem>
                                <ComboBoxItem>Gối cố định</ComboBoxItem>
                                <ComboBoxItem>Gối di động</ComboBoxItem>
                                <ComboBoxItem>Khớp</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Chiều dài (L):" Width="110"/>
                            <TextBox Name="txtDaiCot" Width="150" Height="28" Background="White"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Momen chân (M):" Width="110"/>
                            <TextBox Name="txtMoMenchan" Width="150" Height="28" Background="White"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button x:Name="btnNhapTuEtab" Command="{Binding cmNhapEtab}" CommandParameter="{Binding ElementName=pgCLParameter}"  
                                        Content="Nhập từ Etab" Width="95" Height="30" Margin="0,0,10,0" Background="#777777" Foreground="White"/>
                            <Button x:Name="btnThem" Command="{Binding cmLuuCot}" CommandParameter="{Binding ElementName=pgCLParameter}" 
                                        Content="Lưu" Width="70" Height="30" Background="#00FF00" Foreground="Black"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="1" FontWeight="Bold" Header="Danh sách cột" Margin="10,5,10,10">
                <DataGrid Name="dtgColumn" AutoGenerateColumns="False" ItemsSource="{Binding clsColumn}" 
                              SelectionChanged="dataGrid_SelectionChanged" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="*" Header="Tên" Binding="{Binding Name}" />
                        <DataGridTextColumn Width="*" Header="Tiết diện" Binding="{Binding TietDien.Name}" />
                        <DataGridTextColumn Width="*" Header="Vật liệu" Binding="{Binding VatLieu.TenVatLieu}" />
                        <DataGridTextColumn Width="*" Header="Chiều cao" Binding="{Binding ChieuCao}" />
                        <DataGridTextColumn Width="*" Header="Tầng" Binding="{Binding Story}" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Column="1" Header="3D View Mô Hình Kết Cấu" Margin="5,10,10,10" FontWeight="Bold">
            <Grid Background="White">
                <helix:HelixViewport3D x:Name="view3D" 
                                           ZoomExtentsWhenLoaded="True" 
                                           ShowCoordinateSystem="True" 
                                           CoordinateSystemHorizontalPosition="Left" 
                                           CoordinateSystemVerticalPosition="Bottom">

                    <helix:DefaultLights/>

                    <helix:GridLinesVisual3D Width="450" Length="450" MajorDistance="10" MinorDistance="10" Thickness="0.1" Fill="Blue" />

                    <ModelVisual3D x:Name="modelContainer" />

                </helix:HelixViewport3D>
            </Grid>
        </GroupBox>
    </Grid>
</Page>