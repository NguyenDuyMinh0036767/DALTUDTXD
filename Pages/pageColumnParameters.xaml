<Page x:Class="HUCE_DALTUD_LOPNV90_2026_0053867.Pages.pageColumnParameters"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HUCE_DALTUD_LOPNV90_2026_0053867.Pages"
      mc:Ignorable="d" 
      x:Name="pgCLParameter"
      DataContext="{StaticResource CLParameterVM}"
      d:DesignHeight="555" d:DesignWidth="1000"
      Title="pageColumnParameters" Background="#DDDDDD">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="280"/>
        </Grid.RowDefinitions>

        <!-- Nhóm nhập thông số -->
        <GroupBox Header="Thông số tiết diện" Width="1000" HorizontalAlignment="Center" VerticalAlignment="Top" FontWeight="Bold" Height="206">
            <Grid>
                <StackPanel HorizontalAlignment="Left" Margin="10,10,0,0">

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Tên cột:" Width="120"/>
                        <TextBox Name="txtName" Width="200" Height="35" Background="White"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Chọn tiết diện:" Width="120"/>
                        <ComboBox x:Name="cbbTietDien" Width="200" Height="35" Background="White"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Tải trọng chân (N):" Width="120"/>
                        <TextBox Name="txtTaiTrongchan" Width="200" Height="35" Background="White"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Tải trọng đỉnh (N):" Width="120"/>
                        <TextBox Name="txtTaiTrongdinh" Width="200" Height="35" Background="White"/>
                    </StackPanel>


                </StackPanel>

                <StackPanel HorizontalAlignment="Center" Margin="0,10,0,0">

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Chọn vật liệu:" Width="120" Height="30"/>
                        <ComboBox Name="cbbVatLieu" Width="200"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Liên kết chân cột:" Width="120"/>
                        <ComboBox Name="cbbLK" Width="200" Height="30" HorizontalContentAlignment="Center">
                            <ComboBoxItem IsSelected="True">Ngàm</ComboBoxItem>
                            <ComboBoxItem>Gối cố định</ComboBoxItem>
                            <ComboBoxItem>Gối di động</ComboBoxItem>
                            <ComboBoxItem>Khớp</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Margin="0,10,10,0">

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Chiều dài cột (L):" Width="120"/>
                        <TextBox Name="txtDaiCot" Width="200" Height="35" Background="White"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Momen chân (M):" Width="120"/>
                        <TextBox Name="txtMoMenchan" Width="200" Height="35" Background="White"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5" >
                        <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="Momen đỉnh(M):" Width="120"/>
                        <TextBox Name="txtMoMendinh" Width="200" Height="35" Background="White"/>
                    </StackPanel>

                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Nút chức năng -->
        <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,10">
            <Button x:Name="btnNhapTuEtab" Command="{Binding cmNhapEtab}" CommandParameter="{Binding ElementName=pgCLParameter}"  
                    Content="Nhập từ Etab" Width="130" Height="50" Margin="0,0,20,0"  
                    Background="#777777" Foreground="White"/>
            <Button x:Name="btnThem" Command="{Binding cmLuuCot}" CommandParameter="{Binding ElementName=pgCLParameter}" 
                    Content="Lưu" Width="130" Height="50" Background="#00FF00" Foreground="Black"/>
        </StackPanel>

        <!-- Danh sách cột -->
        <GroupBox Grid.Row="1" FontWeight="Bold" Header="Danh sách cột" Margin="10,10,10,10">
            <DataGrid Name="dtgColumn"
          AutoGenerateColumns="False"
          ItemsSource="{Binding clsColumn}" 
          SelectionChanged="dataGrid_SelectionChanged"
          IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="*" Header="Tên" Binding="{Binding Name}" />
                    <DataGridTextColumn Width="*" Header="Tiết diện" Binding="{Binding TietDien.Name}" />
                    <DataGridTextColumn Width="*" Header="Vật liệu" Binding="{Binding VatLieu.TenVatLieu}" />
                    <DataGridTextColumn Width="*" Header="Chiều cao" Binding="{Binding ChieuCao}" />
                    <DataGridTextColumn Width="*" Header="Tầng" Binding="{Binding Story}" />
                </DataGrid.Columns>
            </DataGrid>

        </GroupBox>

    </Grid>
</Page>
