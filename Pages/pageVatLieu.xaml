<Page x:Class="HUCE_DALTUD_LOPNV90_2026_0053867.Pages.pageVatLieu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HUCE_DALTUD_LOPNV90_2026_0053867.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="565" d:DesignWidth="800"
      Title="VẬT LIỆU " Background="#DDDDDD">

    <Page.Resources>
        <!-- Màu sắc -->
        <SolidColorBrush x:Key="ChuDao1" Color="#5c96ff"/>
        <SolidColorBrush x:Key="ChuDao2" Color="#4569eb"/>
        <SolidColorBrush x:Key="ChuDao3" Color="#96c5ff"/>
        <SolidColorBrush x:Key="ChuDao4" Color="#9be7ff"/>

        <!-- Style button bo góc + chữ đậm -->
        <Style TargetType="Button" x:Key="RoundedButton">
            <Setter Property="Background" Value="{StaticResource ChuDao1}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF7B68EE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF5A4DCB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style DataGrid -->
        <Style TargetType="DataGrid" x:Key="MaterialDataGridStyle">
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F3F3F3"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="ColumnHeaderHeight" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#DDD"/>
            <Setter Property="VerticalGridLinesBrush" Value="#DDD"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>

        <!-- Style TextBlock chữ đậm -->
        <Style TargetType="TextBlock" x:Key="BoldText">
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Page.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="10"/>

            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Tiêu đề -->
        <TextBlock Text="QUẢN LÝ VẬT LIỆU THÉP" FontSize="24" HorizontalAlignment="Center" Margin="0,10,0,20" Style="{StaticResource BoldText}" Grid.RowSpan="2"/>

        <!-- Khu vực nhập liệu -->
        <GroupBox Header="Thông số vật liệu" Margin="0,36,0,0" VerticalAlignment="Top" FontWeight="Bold" Grid.Row="1">
            <StackPanel Margin="10">
                <TextBlock Text="Tên vật liệu:" Margin="0,5,0,2" Style="{StaticResource BoldText}"/>
                <TextBox HorizontalAlignment="Left" Name="txtName" Width="250" Height="35" Background="White" />
                <TextBlock Text="Modul đàn hồi (E) [MPa]:" Margin="0,10,0,2" Style="{StaticResource BoldText}"/>
                <TextBox HorizontalAlignment="Left" Name="txtMoDunDanHoi" Width="250" Height="35" Background="White"/>
                <TextBlock Text="Cường độ chịu kéo chảy (Fy) [MPa]:" Margin="0,10,0,2" Style="{StaticResource BoldText}"/>
                <TextBox HorizontalAlignment="Left" Name="txtCuongDoKeoChay" Width="250" Height="35" Background="White"/>
            </StackPanel>
        </GroupBox>

        <!-- Khu vực button -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,85,10,0" Grid.Row="1" RenderTransformOrigin="0.509,-4.734" Height="160">
            <Button x:Name="SaveButton" Style="{StaticResource RoundedButton}" Content="Lưu vật liệu" Background="#33FF33" Height="50" Click="SaveButton_Click"/>
            <Button x:Name="EditButton" Style="{StaticResource RoundedButton}" Content="Sửa vật liệu" Background="#666666" Height="50" Click="EditButton_Click"/>
            <Button x:Name="DeleteButton" Style="{StaticResource RoundedButton}" Content="Xóa vật liệu" Background="#FF0000" Height="50" Click="DeleteButton_Click"/>
        </StackPanel>

        <!-- Khu vực hiển thị danh sách vật liệu -->
        <GroupBox Header="Danh sách vật liệu đã lưu"
          Margin="0,276,0,0"
          FontWeight="Bold"
          FontSize="14" Grid.Row="1">

            <DataGrid Name="MaterialDataGrid"
              AutoGenerateColumns="False"
              ItemsSource="{Binding clsVatLieu}"
              IsReadOnly="True"
              FontSize="14"
              Style="{StaticResource MaterialDataGridStyle}"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              SelectionMode="Single"
              Margin="0,0,0,-12">

                <DataGrid.Columns>
                    <DataGridTextColumn Width="*"  Header="Tên"  Binding="{Binding TenVatLieu}" />

                    <DataGridTextColumn Width="*"  Header="Mô đun đàn hồi (E)" Binding="{Binding MoDunDanHoi}" />

                    <DataGridTextColumn Width="*"  Header="Cường độ chịu kéo (Fy)"  Binding="{Binding CuongDoChiuKeo}" />
                </DataGrid.Columns>

            </DataGrid>
        </GroupBox>

    </Grid>
</Page>
