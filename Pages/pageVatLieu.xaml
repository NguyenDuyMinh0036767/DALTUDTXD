<Page x:Class="HUCE_DALTUD_LOPNV90_2026_0053867.Pages.pageVatLieu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="565"
      d:DesignWidth="800"
      Title="VẬT LIỆU"
      Background="#DDDDDD">

    <Page.Resources>

        <!-- Style Button -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#5C96FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="5">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder"
                                        Property="Background"
                                        Value="#7B68EE"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder"
                                        Property="Background"
                                        Value="#5A4DCB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style DataGrid -->
        <Style x:Key="MaterialDataGridStyle" TargetType="DataGrid">
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F3F3F3"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="ColumnHeaderHeight" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#DDD"/>
            <Setter Property="VerticalGridLinesBrush" Value="#DDD"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>

        <!-- Text đậm -->
        <Style x:Key="BoldText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

    </Page.Resources>

    <Grid Margin="10">

        <!-- Tiêu đề -->
        <TextBlock Text="QUẢN LÝ VẬT LIỆU THÉP"
                   FontSize="24"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,20"
                   Style="{StaticResource BoldText}"/>

        <!-- Nhập liệu -->
        <GroupBox Header="Thông số vật liệu"
                  Margin="0,50,0,0"
                  VerticalAlignment="Top"
                  FontWeight="Bold">

            <StackPanel Margin="10">

                <TextBlock Text="Tên vật liệu:"
                           Margin="0,5"
                           Style="{StaticResource BoldText}"/>

                <TextBox x:Name="txtName"
                         Width="250"
                         Height="35"
                         Background="White"/>

                <TextBlock Text="Mô đun đàn hồi (E) [MPa]:"
                           Margin="0,10,0,5"
                           Style="{StaticResource BoldText}"/>

                <TextBox x:Name="txtMoDunDanHoi"
                         Width="250"
                         Height="35"
                         Background="White"/>

                <TextBlock Text="Cường độ chịu kéo chảy (Fy) [MPa]:"
                           Margin="0,10,0,5"
                           Style="{StaticResource BoldText}"/>

                <TextBox x:Name="txtCuongDoKeoChay"
                         Width="250"
                         Height="35"
                         Background="White"/>

            </StackPanel>
        </GroupBox>

        <!-- Nút chức năng -->
        <StackPanel Orientation="Vertical"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,100,10,0">

            <Button x:Name="EditButton"
                    Style="{StaticResource RoundedButton}"
                    Content="Sửa vật liệu"
                    Background="#777777"
                    Click="EditButton_Click"/>
            <Button x:Name="SaveButton"
                    Style="{StaticResource RoundedButton}"
                    Content="Lưu vật liệu"
                    Background="#33FF33"
                    Foreground="Black"
                    Click="SaveButton_Click"/>

            <Button x:Name="DeleteButton"
                    Style="{StaticResource RoundedButton}"
                    Content="Xóa vật liệu"
                    Background="#FF0000"
                    Foreground="Black"
                    Click="DeleteButton_Click"/>

        </StackPanel>

        <!-- Danh sách vật liệu -->
        <GroupBox Header="Danh sách vật liệu đã lưu"
                  Margin="0,280,0,0"
                  FontWeight="Bold"
                  FontSize="14">

            <DataGrid x:Name="MaterialDataGrid"
                      AutoGenerateColumns="False"
                      ItemsSource="{Binding clsVatLieu}"
                      IsReadOnly="True"
                      FontSize="14"
                      Style="{StaticResource MaterialDataGridStyle}">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Tên"
                                        Width="*"
                                        Binding="{Binding TenVatLieu}"/>

                    <DataGridTextColumn Header="Mô đun đàn hồi (E)"
                                        Width="*"
                                        Binding="{Binding MoDunDanHoi}"/>

                    <DataGridTextColumn Header="Cường độ chịu kéo (Fy)"
                                        Width="*"
                                        Binding="{Binding CuongDoChiuKeo}"/>

                </DataGrid.Columns>

            </DataGrid>

        </GroupBox>

    </Grid>

</Page>