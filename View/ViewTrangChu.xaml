<Window x:Class="HUCE_DALTUD_LOPNV90_2026_0053867.View.ViewTrangChu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PHẦN MỀM TÍNH TOÁN THÉP TỔ HỢP CHỮ I"
        Height="800"
        Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions  >
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Ribbon x:Name="rbncontrol"
                Background="#F3F3F3"
                Foreground="Black" 
                SelectedIndex="0">

            <Ribbon.ApplicationMenu>
                <RibbonApplicationMenu KeyTip="F">
                    <RibbonApplicationMenuItem Header="Tài khoản"/>
                    <RibbonApplicationMenuItem Header="Đăng xuất"/>
                    <RibbonApplicationMenuItem Header="Cài đặt"/>
                </RibbonApplicationMenu>
            </Ribbon.ApplicationMenu>

            <RibbonTab Header="Tiết diện">

                <RibbonGroup Header="Material">
                    <RibbonButton x:Name="btnVatLieu"
                                  LargeImageSource="/Resources/Anh/steel.png"
                                  Label="Material"
                                  Click="btnVatLieu_Click"
                                  ToolTipTitle="Vật liệu mác thép"
                                  ToolTipDescription="Cài đặt các thông số cơ lý của thép tổ hợp."/>
                </RibbonGroup>

                <RibbonGroup Header="Thông số cột">

                    <RibbonButton x:Name="btnThongSoCot"
                                  LargeImageSource="/Resources/Anh/5672201.png"
                                  Label="Column parameters"
                                  Click="btnThongSoCot_Click"/>

                    <RibbonButton x:Name="btnTietDien"
                                  LargeImageSource="/Resources/Anh/i.png"
                                  Label="Sections"
                                  Click="btnTietDien_Click"/>

                </RibbonGroup>
            </RibbonTab>

            <RibbonTab Header="Tính toán">
                <RibbonGroup Header="Tính toán">

                    <RibbonButton x:Name="btnTinhToanKNCNLechTam"
                                  LargeImageSource="/Resources/Anh/maytinh.png"
                                  Label="KTra nén lệch tâm"
                                  Click="btnTinhToanKNCNLechTam_Click"
                                  ToolTipTitle="Kiểm tra cấu kiện"
                                  ToolTipDescription="Tính toán kiểm tra khả năng chịu lực nén uốn đồng thời của cột chữ I."/>

                    <RibbonButton x:Name="btnLuuDuAn"
                                  LargeImageSource="/Resources/Anh/save.png"
                                  Label="Lưu dự án"
                                  Click="btnLuuDuAn_Click"/>

                </RibbonGroup>
            </RibbonTab>

            <RibbonTab Header="Báo cáo">
                <RibbonGroup Header="Xuất kết quả">

                    <RibbonButton x:Name="btnExportExcel"
                                  LargeImageSource="/Resources/Anh/excel.png"
                                  Label="Excel"/>

                    <RibbonButton x:Name="btnExportPdf"
                                  LargeImageSource="/Resources/Anh/pdf.png"
                                  Label="PDF"/>

                </RibbonGroup>
            </RibbonTab>

            <RibbonTab Header="Hỗ trợ">
                <RibbonGroup Header="Thông tin">

                    <RibbonButton x:Name="btnHuongDan"
                                  LargeImageSource="/Resources/Anh/help.png"
                                  Label="Hướng dẫn"/>

                    <RibbonButton x:Name="btnCaiDatNangCao"
                                  LargeImageSource="/Resources/Anh/settings.png"
                                  Label="Cài đặt nâng cao"/>

                </RibbonGroup>
            </RibbonTab>

        </Ribbon>

        <Frame x:Name="frame_Body" Grid.Row="1" NavigationUIVisibility="Hidden">
            <Frame.Background>
                <ImageBrush ImageSource="/Resources/Anh/hinhnenxam.jpg" 
                            Stretch="UniformToFill"/>
            </Frame.Background>
        </Frame>
    </Grid>
</Window>