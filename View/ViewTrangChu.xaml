<Window x:Class="HUCE_DALTUD_LOPNV90_2026_0053867.View.ViewTrangChu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PHẦN MỀM TÍNH TOÁN THÉP TỔ HỢP CHỮ I"
        Height="800"
        Width="1000"
        WindowStartupLocation="CenterScreen">

    <!-- ================= LOCAL STYLE (CHỈ RIÊNG RIBBON) ================= -->
    <Window.Resources>

        <!-- Button dùng cho Ribbon -->
        <Style x:Key="RibbonRoundedButton"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">

            <Setter Property="Height" Value="60"/>
            <Setter Property="Width" Value="125"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#BBBBBB"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="5">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CCCCFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CCCCFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ================= LAYOUT ================= -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="135"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- ================= RIBBON ================= -->
        <Ribbon x:Name="rbncontrol"
                Background="#CCCCCC"
                Foreground="Black" SelectedIndex="0">

            <!-- App Menu -->
            <Ribbon.ApplicationMenu>
                <RibbonApplicationMenu KeyTip="F">
                    <RibbonApplicationMenuItem Header="Tài khoản"/>
                    <RibbonApplicationMenuItem Header="Đăng xuất"/>
                    <RibbonApplicationMenuItem Header="Cài đặt"/>
                </RibbonApplicationMenu>
            </Ribbon.ApplicationMenu>


            <!-- ========== TAB: TIẾT DIỆN ========== -->
            <RibbonTab Header="Tiết diện">

                <RibbonGroup Header="Material">

                    <Button Style="{StaticResource RibbonRoundedButton}"
                            Click="btnVatLieu_Click">
                        <StackPanel>
                            <Image Source="/Resources/Anh/steel.png" Width="30"/>
                            <TextBlock Text="Material" TextAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!--<Button Style="{StaticResource RibbonRoundedButton}"
                            Click="btnDoBenKeo_Click">
                        <StackPanel>
                            <Image Source="/Resources/Anh/steel.png" Width="30"/>
                            <TextBlock Text="Tensile Strength" TextAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource RibbonRoundedButton}"
                            Click="btnGioiHanChay_Click">
                        <StackPanel>
                            <Image Source="/Resources/Anh/steel.jpg" Width="30"/>
                            <TextBlock Text="Yield Strength" TextAlignment="Center"/>
                        </StackPanel>
                    </Button>-->

                </RibbonGroup>

                <RibbonGroup Header="Thông số cột">

                    <Button Style="{StaticResource RibbonRoundedButton}"
                            Click="btnThongSoCot_Click">
                        <StackPanel>
                            <Image Source="/Resources/Anh/5672201.png" Width="30"/>
                            <TextBlock Text="Column parameters" TextAlignment="Center" Foreground="Black"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource RibbonRoundedButton}"
                            Click="btnTietDien_Click">
                        <StackPanel>
                            <Image Source="/Resources/Anh/i.png" Width="20"/>
                            <TextBlock Text="Sections" TextAlignment="Center" Foreground="Black"/>
                        </StackPanel>
                    </Button>


                </RibbonGroup>
            </RibbonTab>

            <!-- ========== TAB: TÍNH TOÁN ========== -->
            <RibbonTab Header="Tính toán">
                <RibbonGroup Header="Tính toán">

                    <Button Style="{StaticResource RibbonRoundedButton}"
                            Click="btnTinhToanKNCNLechTam_Click">
                        <StackPanel>
                            <Image Source="/Resources/Anh/maytinh.png" Width="35"/>
                            <TextBlock Text="KTra nén lệch tâm"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource RibbonRoundedButton}"
                            Click="btnLuuDuAn_Click">
                        <StackPanel>
                            <Image Source="/Resources/Anh/save.png" Width="30"/>
                            <TextBlock Text="Lưu dự án" TextAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </RibbonGroup>
            </RibbonTab>

            <!-- ========== TAB: BÁO CÁO ========== -->
            <RibbonTab Header="Báo cáo">
                <RibbonGroup Header="Xuất kết quả">

                    <Button Style="{StaticResource RibbonRoundedButton}">
                        <StackPanel>
                            <Image Source="/Resources/Anh/excel.png" Width="30"/>
                            <TextBlock Text="Excel" TextAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource RibbonRoundedButton}">
                        <StackPanel>
                            <Image Source="/Resources/Anh/pdf.png" Width="30"/>
                            <TextBlock Text="PDF" TextAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </RibbonGroup>
            </RibbonTab>

            <!-- ========== TAB: HỖ TRỢ ========== -->
            <RibbonTab Header="Hỗ trợ">
                <RibbonGroup Header="Thông tin">

                    <Button Style="{StaticResource RibbonRoundedButton}">
                        <StackPanel>
                            <Image Source="/Resources/Anh/help.png" Width="30"/>
                            <TextBlock Text="Hướng dẫn" TextAlignment="Center" Foreground="Black"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource RibbonRoundedButton}">
                        <StackPanel>
                            <Image Source="/Resources/Anh/settings.png" Width="30"/>
                            <TextBlock Text="Cài đặt nâng cao"
                                       TextAlignment="Center"
                                       Foreground="Black"/>
                        </StackPanel>
                    </Button>

                </RibbonGroup>
            </RibbonTab>

        </Ribbon>

        <!-- ================= BODY ================= -->
        <Frame x:Name="frame_Body" Grid.Row="1">
            <Frame.Background>
                <ImageBrush ImageSource="/Resources/Anh/anhnen.png" 
                    Stretch="UniformToFill"/>
            </Frame.Background>
        </Frame>
    </Grid>
</Window>
