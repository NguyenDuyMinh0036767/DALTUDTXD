<Window x:Class="HUCE_DALTUD_LOPNV90_2026_0053867.View.ViewDangNhap"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HUCE_DALTUD_LOPNV90_2026_0053867.View"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Đăng Nhập"
        Height="550"
        Width="350"
        Background="White"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>

        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#CCCCCC"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="mainBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderThickness="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="mainBorder" Property="Background" Value="#CCCCFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="mainBorder" Property="Background" Value="#CCCCFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Resources/Anh/hinhnen.jpg" 
                    Stretch="UniformToFill"/>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <TextBlock
            Text="Đăng Nhập"
            HorizontalAlignment="Center"
            Margin="0,30,0,20"
            FontSize="32"
            FontWeight="Bold"
            Foreground="White"/>

        <!-- Form -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center">

            <!-- Tên đăng nhập với Watermark -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                <TextBlock Text="👤" FontSize="24" Width="30" VerticalAlignment="Center" Margin="0,0,10,0" Background="#EAEAEA" />
                <Grid Width="220">
                    <TextBox x:Name="txtName" VerticalContentAlignment="Center" Padding="5" Background="#EAEAEA"/>
                    <TextBlock Text="Tên đăng nhập"
                               Foreground="Black"
                               IsHitTestVisible="False"
                               Margin="5,0,0,0"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <!-- Hiển thị Watermark khi TextBox rỗng -->
                                    <DataTrigger Binding="{Binding Text, ElementName=txtName}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Text, ElementName=txtName}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <!-- Ẩn Watermark khi có chữ -->
                                    <DataTrigger Binding="{Binding Text, ElementName=txtName}" Value="{x:Static sys:String.Empty}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </Grid>
            </StackPanel>

            <!-- Mật khẩu -->
            <StackPanel Orientation="Horizontal" Margin="0,20,0,0" VerticalAlignment="Center">
                <TextBlock Text="🔒" FontSize="24" Width="30" VerticalAlignment="Center" Margin="0,0,10,0" Background="#EAEAEA" />
                <PasswordBox                    
                    Width="220"
                    x:Name="PasswordBox"
                    VerticalContentAlignment="Center"
                    Padding="5"
                    ToolTip="Ít nhất 8 ký tự" Background="#EAEAEA"/>
            </StackPanel>

        </StackPanel>

        <!-- Các nút phụ -->
        <StackPanel Grid.Row="2" Margin="0,30,0,0" HorizontalAlignment="Center">

            <Button Content="Đăng nhập" 
                    Style="{StaticResource RoundedButton}"
                    FontSize="18" 
                    Margin="0,20,0,0" 
                    Click="btnDangNhap_Click"/>

            <Button Content="Đăng ký" 
                    Style="{StaticResource RoundedButton}"
                    FontSize="18" Margin="0,20,0,0" />


            <Button Content="Thoát" 
                    Style="{StaticResource RoundedButton}"
                    FontSize="18" Margin="0,20,0,0"/>

        </StackPanel>

    </Grid>
</Window>
