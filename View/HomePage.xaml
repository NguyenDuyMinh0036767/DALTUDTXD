<Window x:Class="HUCE_DALTUD_LOPNV90_2026_0053867.HomePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Phần mềm tính toán cột thép chữ I"
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.Background>
        <ImageBrush ImageSource="/Resources/Anh/anhnen.png" 
                    Stretch="None" 
            AlignmentX="Left" 
            AlignmentY="Top"
                    Opacity="1.0"/>
    </Window.Background>

    <!-- ================= LOCAL STYLE (KHÔNG KHAI BÁO MÀU) ================= -->
    <Window.Resources>

        <!-- Button bo góc – dùng màu từ App.xaml -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#CCCCCC"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderThickness="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CCCCFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CCCCFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ================= LAYOUT ================= -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- Background trái -->
        <Border Grid.Row="0"
                Grid.RowSpan="3"
                Background="Transparent"
                Margin="10"
                CornerRadius="10"/>

        <!-- Logo -->

        <!-- Tiêu đề -->
        <TextBlock Grid.Column="1"
                   Grid.Row="1"
                   Text="Phần mềm tính toán cột thép chữ I"
                   FontSize="40"
                   FontWeight="Bold"
                   Foreground="Black"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Left" Margin="30,0,0,0"/>

        <!-- Ghi chú -->
        <Border Grid.Column="1"
                Grid.Row="1"
                Background="{StaticResource ChuDao4}"
                CornerRadius="10"
                Height="40"
                Margin="28,311,12,33">
            <TextBlock Text="Ghi chú"
                       Foreground="{StaticResource ChuDao2}"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"/>
        </Border>

        <!-- Menu trái -->
        <StackPanel Grid.Column="0"
                    Grid.Row="1"
                    
                    Margin="20,200,20,0"
                    VerticalAlignment="Top">
            <Button Content="Tính toán"
                    FontSize="20"
                    Style="{StaticResource RoundedButton}"
                    Click="btnTaoMoi_Click"/>

            <Button Content="Mở tài liệu"
                    FontSize="20"
                    Style="{StaticResource RoundedButton}"/>

            <!--<Button Content="Xuất báo cáo"
                    FontSize="20"
                    Style="{StaticResource RoundedButton}"/>-->

            <Button Content="Cài đặt"
                    FontSize="20"
                    Style="{StaticResource RoundedButton}"/>
        </StackPanel>

        <!-- Hỗ trợ -->
        <StackPanel Grid.Column="0"
                    Grid.Row="2"
                    Margin="20"
                    VerticalAlignment="Bottom">

            <Button Content="Hỗ trợ"
                    FontSize="20"
                    Style="{StaticResource RoundedButton}"/>

            <!--<Button Content="Tiêu chuẩn Việt Nam"
                    FontSize="20"
                    Style="{StaticResource RoundedButton}"/>-->
        </StackPanel>

        <!-- Nội dung chính -->
        <Border Grid.Column="1"
                Grid.Row="1"
                Margin="28,209,12,91"
                Background="#666666"
                CornerRadius="10" Grid.RowSpan="2">

            <RichTextBox Background="White"
                         Foreground="Black"
                         FontWeight="Bold"
                         FontSize="14"
                         Margin="10"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto">

                <FlowDocument>
                    <Paragraph FontSize="20" FontWeight="Bold">
                        Chào mừng đến với phần mềm tính toán cột thép chữ I.
                    </Paragraph>
                    <Paragraph FontSize="20" FontWeight="Bold">
                        Bạn có thể chọn các chức năng bên trái để bắt đầu.
                    </Paragraph>
                </FlowDocument>


            </RichTextBox>
        </Border>
        <Image Source="/Resources/Anh/icontinhtoan.png"
            Width="141"
            Height="238"
            Margin="516,311,0,0"
            VerticalAlignment="Top"
            HorizontalAlignment="Left" Grid.Column="1" Grid.Row="1" Grid.RowSpan="2"/>

    </Grid>
</Window>
