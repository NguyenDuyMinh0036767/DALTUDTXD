<Application x:Class="HUCE_DALTUD_LOPNV90_2026_0053867.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="View/ViewDangNhap.xaml">

    <Application.Resources>
        <ResourceDictionary>

            <!-- ================= MERGED DICTIONARIES ================= -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Color.xaml"/>
                <ResourceDictionary Source="Resources/MainViewModel.xaml"/>
            </ResourceDictionary.MergedDictionaries>


            <!-- ================= FONT ================= -->
            <FontFamily x:Key="FontChinh">Segoe UI</FontFamily>

            <!-- ================= TEXTBLOCK ================= -->
            <Style x:Key="TextBase" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontChinh}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{StaticResource ChuDao2}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="TextTitle"
                   TargetType="TextBlock"
                   BasedOn="{StaticResource TextBase}">
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <!-- ⬇ ChuDao3 → ChuDao4 -->
                <Setter Property="Foreground" Value="{StaticResource ChuDao4}"/>
            </Style>

            <Style x:Key="TextLabel"
                   TargetType="TextBlock"
                   BasedOn="{StaticResource TextBase}">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Medium"/>
            </Style>

            <!-- ================= BUTTON (GLOBAL) ================= -->
            <Style TargetType="Button">
                <Setter Property="FontFamily" Value="{StaticResource FontChinh}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="White"/>
                <!-- ⬇ ChuDao3 → ChuDao4 -->
                <Setter Property="Background" Value="{StaticResource ChuDao4}"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6">
                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>

                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Opacity" Value="0.9"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.5"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ================= TEXTBOX ================= -->
            <Style TargetType="TextBox">
                <Setter Property="FontFamily" Value="{StaticResource FontChinh}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{StaticResource ChuDao2}"/>
                <Setter Property="Background" Value="{StaticResource ChuDao1}"/>
                <Setter Property="Padding" Value="8"/>
                <Setter Property="BorderThickness" Value="1"/>
                <!-- ⬇ ChuDao3 → ChuDao4 -->
                <Setter Property="BorderBrush" Value="{StaticResource ChuDao4}"/>
            </Style>

            <!-- ================= WINDOW ================= -->
            <Style TargetType="Window">
                <Setter Property="FontFamily" Value="{StaticResource FontChinh}"/>
                <Setter Property="Background" Value="{StaticResource ChuDao1}"/>
            </Style>

            <!-- ================= RIBBON BUTTON ================= -->
            <Style x:Key="RibbonRoundedButton"
                   TargetType="Button"
                   BasedOn="{StaticResource {x:Type Button}}">

                <Setter Property="Height" Value="60"/>
                <Setter Property="Width" Value="120"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <!-- ⬇ ChuDao3 → ChuDao4 -->
                <Setter Property="Background" Value="{StaticResource ChuDao4}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Cursor" Value="Hand"/>

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="10"
                                    Padding="6">
                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF6FA8FF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#FF3F7FD9"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
